# Copy to .env or let start-graylog.ps1 generate deploy/graylog/.env.
# Keep deploy/graylog/.env private and uncommitted.

GRAYLOG_IMAGE=graylog/graylog:7.1
MONGODB_IMAGE=mongo:6.0.18
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.15.0

GRAYLOG_HTTP_EXTERNAL_URI=http://127.0.0.1:9000/
GRAYLOG_PASSWORD_SECRET=change-me-at-least-16-characters

# SHA-256 hash of the Graylog admin password.
# The value below is SHA-256("admin") and is suitable only for disposable local development.
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# Required by recent OpenSearch images even when security is disabled.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change-me-OpenSearch-Admin-Password-32

